{
  "name": "@mcploom/codexec",
  "version": "0.2.2",
  "description": "Executor-agnostic MCP code execution core and MCP adapters.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sandbox",
    "code-execution",
    "tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aallam/mcploom.git",
    "directory": "packages/codexec"
  },
  "homepage": "https://github.com/aallam/mcploom/tree/main/packages/codexec#readme",
  "bugs": "https://github.com/aallam/mcploom/issues",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "acorn": "^8.15.0",
    "ajv": "^8.17.1",
    "zod": "^4.3.6"
  }
}
