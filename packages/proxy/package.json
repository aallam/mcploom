{
  "name": "@mcploom/proxy",
  "version": "0.3.1",
  "description": "Lightweight MCP proxy that aggregates multiple MCP servers behind a single endpoint.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxy",
    "gateway",
    "aggregator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aallam/mcploom.git",
    "directory": "packages/proxy"
  },
  "homepage": "https://github.com/aallam/mcploom/tree/main/packages/proxy#readme",
  "bugs": "https://github.com/aallam/mcploom/issues",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mcploom/analytics": "*"
  }
}
