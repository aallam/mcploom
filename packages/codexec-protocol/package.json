{
  "name": "@mcploom/codexec-protocol",
  "version": "0.1.0",
  "description": "Transport-safe protocol and dispatcher helpers for mcploom codexec executors.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "protocol",
    "sandbox",
    "code-execution"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aallam/mcploom.git",
    "directory": "packages/codexec-protocol"
  },
  "homepage": "https://github.com/aallam/mcploom/tree/main/packages/codexec-protocol#readme",
  "bugs": "https://github.com/aallam/mcploom/issues",
  "dependencies": {
    "@mcploom/codexec": "^0.2.5"
  }
}
