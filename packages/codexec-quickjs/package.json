{
  "name": "@mcploom/codexec-quickjs",
  "version": "0.1.6",
  "description": "QuickJS executor for the mcploom codexec core package.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runner": {
      "types": "./dist/runner/index.d.ts",
      "import": "./dist/runner/index.js",
      "require": "./dist/runner/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "quickjs",
    "sandbox",
    "code-execution"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aallam/mcploom.git",
    "directory": "packages/codexec-quickjs"
  },
  "homepage": "https://github.com/aallam/mcploom/tree/main/packages/codexec-quickjs#readme",
  "bugs": "https://github.com/aallam/mcploom/issues",
  "dependencies": {
    "@mcploom/codexec": "^0.2.5",
    "@mcploom/codexec-protocol": "^0.1.0",
    "quickjs-emscripten": "^0.31.0"
  }
}
