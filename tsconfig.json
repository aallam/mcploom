{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@mcploom/analytics": ["./packages/analytics/src/index.ts"],
      "@mcploom/proxy": ["./packages/proxy/src/index.ts"],
      "@mcploom/codexec": ["./packages/codexec/src/index.ts"],
      "@mcploom/codexec/mcp": ["./packages/codexec/src/mcp/index.ts"],
      "@mcploom/codexec-protocol": ["./packages/codexec-protocol/src/index.ts"],
      "@mcploom/codexec-quickjs": ["./packages/codexec-quickjs/src/index.ts"],
      "@mcploom/codexec-quickjs/runner": [
        "./packages/codexec-quickjs/src/runner/index.ts"
      ],
      "@mcploom/codexec-quickjs/runner/protocol-endpoint": [
        "./packages/codexec-quickjs/src/runner/protocolEndpoint.ts"
      ],
      "@mcploom/codexec-remote": ["./packages/codexec-remote/src/index.ts"],
      "@mcploom/codexec-process": ["./packages/codexec-process/src/index.ts"],
      "@mcploom/codexec-worker": ["./packages/codexec-worker/src/index.ts"],
      "@mcploom/codexec-isolated-vm": [
        "./packages/codexec-isolated-vm/src/index.ts"
      ],
      "@mcploom/codexec-isolated-vm/runner": [
        "./packages/codexec-isolated-vm/src/runner/index.ts"
      ]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "examples/**/*.ts",
    "examples/codexec-isolated-vm-basic.ts",
    "packages/analytics/**/*.ts",
    "packages/proxy/**/*.ts",
    "packages/codexec/**/*.ts",
    "packages/codexec-protocol/**/*.ts",
    "packages/codexec-quickjs/**/*.ts",
    "packages/codexec-remote/**/*.ts",
    "packages/codexec-process/**/*.ts",
    "packages/codexec-worker/**/*.ts",
    "packages/codexec-isolated-vm/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/node_modules", "packages/*/dist"]
}
