{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@mcploom/analytics": ["./packages/analytics/src/index.ts"],
      "@mcploom/proxy": ["./packages/proxy/src/index.ts"],
      "@mcploom/codexec": ["./packages/codexec/src/index.ts"],
      "@mcploom/codexec/mcp": ["./packages/codexec/src/mcp/index.ts"],
      "@mcploom/codexec-quickjs": ["./packages/codexec-quickjs/src/index.ts"],
      "@mcploom/codexec-isolated-vm": [
        "./packages/codexec-isolated-vm/src/index.ts"
      ]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "examples/**/*.ts",
    "packages/analytics/**/*.ts",
    "packages/proxy/**/*.ts",
    "packages/codexec/**/*.ts",
    "packages/codexec-quickjs/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
